<script>
loadStats();
loadAll();

function loadStats() {
    fetch('/api/knowledge/stats')
        .then(r => r.json())
        .then(data => {
            document.getElementById('statKnowledge').textContent = data.knowledge_count || 0;
            document.getElementById('statIndex').textContent = data.index_count || 0;
        });
}

function loadAll() {
    fetch('/api/knowledge/list')
        .then(r => r.json())
        .then(renderList);
}

function renderList(items) {
    const container = document.getElementById('knowledgeList');
    if (!items || items.length === 0) {
        container.innerHTML = '<div class="text-center text-muted py-4">йҸҶеӮӣжЈӨйҗӯгғЁзҳ‘йҸүпј„жҙ°й”ӣеІғоҮ¬йҚҸе қз¶ҚйҚҸ?/div>';
        return;
    }
    let html = '<div class="list-group list-group-flush">';
    items.forEach(item => {
        const date = item.createdAt ? new Date(item.createdAt).toLocaleString('zh-CN') : '';
        html += '<div class="list-group-item list-group-item-action knowledge-item">' +
            '<div class="d-flex justify-content-between align-items-start">' +
            '<div class="flex-grow-1">' +
            '<div class="fw-semibold">' + escapeHtml(item.title) + '</div>' +
            '<div class="text-muted small mt-1">' + escapeHtml(item.content.substring(0, 120)) + (item.content.length > 120 ? '...' : '') + '</div>' +
            '</div>' +
            '<div class="text-end ms-3">' +
            '<span class="badge bg-info category-badge">' + escapeHtml(item.category || 'йҸҲоҒ„еһҺз»«?) + '</span>' +
            '<div class="mt-2">' +
            '<button class="btn btn-outline-danger btn-sm py-0 px-1" title="йҚ’зҠ»ж«Һ" onclick="del(' + item.id + ')">йҰғжЈҸ</button>' +
            '</div>' +
            '</div>' +
            '</div>' +
            (item.keywords ? '<div class="mt-1">' + item.keywords.split(',').map(k => '<span class="kw-tag">' + escapeHtml(k.trim()) + '</span>').join('') + '</div>' : '') +
            '<div class="text-muted small mt-1">йҸүгғҰз°®й”ӣ? + escapeHtml(item.source || 'йҺөе¬Әе§©жқҲж’іеҸҶ') + ' | ' + date + '</div>' +
            '</div>';
    });
    html += '</div>';
    container.innerHTML = html;
}

function ingest() {
    const title = document.getElementById('ingestTitle').value.trim();
    const content = document.getElementById('ingestContent').value.trim();
    const category = document.getElementById('ingestCategory').value.trim();
    if (!title || !content) { showMsg('йҸҚеӣ¬о•ҪйҚңеұҪе”ҙзҖ№йҖӣз¬үй‘іжҲ’иҙҹз»Ң?, 'danger'); return; }
    fetch('/api/knowledge/ingest', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({title: title, content: content, category: category || 'йҸҲоҒ„еһҺз»«?, source: 'WebйҗЈеІ„жҪ°'})
    })
    .then(r => { if (!r.ok) throw new Error('иӨ°жӣһеҸҶжҫ¶иҫ«и§Ұ'); return r.json(); })
    .then(() => {
        document.getElementById('ingestTitle').value = '';
        document.getElementById('ingestContent').value = '';
        document.getElementById('ingestCategory').value = '';
        showMsg('иӨ°жӣһеҸҶйҺҙж„¬е§ӣ', 'success');
        loadAll(); loadStats();
    })
    .catch(err => showMsg(err.message, 'danger'));
}

function del(id) {
    if (!confirm('зәӯоҶҝо…»йҚ’зҠ»ж«Һй”ӣ?)) return;
    fetch('/api/knowledge/' + id, { method: 'DELETE' })
        .then(r => { if (!r.ok) throw new Error('йҚ’зҠ»ж«Һжҫ¶иҫ«и§Ұ'); showMsg('йҚ’зҠ»ж«ҺйҺҙж„¬е§ӣ', 'success'); loadAll(); loadStats(); })
        .catch(err => showMsg(err.message, 'danger'));
}

function rebuildIndex() {
    fetch('/api/knowledge/rebuild-index', { method: 'POST' })
        .then(r => r.text())
        .then(msg => { showMsg(msg, 'success'); loadStats(); })
        .catch(err => showMsg(err.message, 'danger'));
}

function showMsg(msg, type) {
    const area = document.getElementById('msgArea');
    area.innerHTML = '<span class="text-' + type + '">' + msg + '</span>';
    setTimeout(() => area.innerHTML = '', 3000);
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// === йҸӮеӣҰж¬ўж¶“е©Ғзҙ¶ ===
function handleFileSelect(event) {
    const file = event.target.files[0];
    if (!file) return;
    document.getElementById('fileLabel').textContent = 'е®ёжҹҘвӮ¬еӨӢе«Ё: ' + file.name;
    showMsg('е§қпҪ…ж№ӘзҖөз…ҺеҸҶйҸӮеӣҰж¬ў: ' + file.name + '...', 'info');

    const formData = new FormData();
    formData.append('file', file);

    fetch('/api/knowledge/import', { method: 'POST', body: formData })
        .then(r => {
            if (!r.ok) {
                return r.json().then(errData => {
                    throw new Error(errData.error || errData.message || 'зҖөз…ҺеҸҶжҫ¶иҫ«и§Ұ');
                }).catch(e => {
                    if (e.message && e.message !== 'зҖөз…ҺеҸҶжҫ¶иҫ«и§Ұ') throw e;
                    throw new Error('зҖөз…ҺеҸҶжҫ¶иҫ«и§Ұ (HTTP ' + r.status + ')');
                });
            }
            return r.json();
        })
        .then(data => {
            showMsg('зҖөз…ҺеҸҶйҺҙж„¬е§ӣй”ӣдҪёеһҺйҗ—еӣЁжҡҹ: ' + data.chunkCount + 'й”ӣеұҪеҸҸзҒһвӮ¬йҚҸжҠҪж•ӯз’Ү? ' + (data.globalKeywords || []).join(', '), 'success');
            document.getElementById('fileLabel').textContent = '';
            document.getElementById('fileInput').value = '';
            loadAll(); loadStats();
        })
        .catch(err => {
            showMsg('зҖөз…ҺеҸҶжҫ¶иҫ«и§Ұ: ' + err.message, 'danger');
            document.getElementById('fileLabel').textContent = '';
            document.getElementById('fileInput').value = '';
        });
}
</script>
</body>
