<script>
loadStats();
loadAll();

function loadStats() {
    fetch('/api/knowledge/stats')
        .then(r => r.json())
        .then(data => {
            document.getElementById('statKnowledge').textContent = data.knowledge_count || 0;
            document.getElementById('statIndex').textContent = data.index_count || 0;
        });
}

function loadAll() {
    fetch('/api/knowledge/list')
        .then(r => r.json())
        .then(renderList);
}

function renderList(items) {
    const container = document.getElementById('knowledgeList');
    if (!items || items.length === 0) {
        container.innerHTML = '<div class="text-center text-muted py-4">鏆傛棤鐭ヨ瘑鏉＄洰锛岃鍏堝綍鍏?/div>';
        return;
    }
    let html = '<div class="list-group list-group-flush">';
    items.forEach(item => {
        const date = item.createdAt ? new Date(item.createdAt).toLocaleString('zh-CN') : '';
        html += '<div class="list-group-item list-group-item-action knowledge-item">' +
            '<div class="d-flex justify-content-between align-items-start">' +
            '<div class="flex-grow-1">' +
            '<div class="fw-semibold">' + escapeHtml(item.title) + '</div>' +
            '<div class="text-muted small mt-1">' + escapeHtml(item.content.substring(0, 120)) + (item.content.length > 120 ? '...' : '') + '</div>' +
            '</div>' +
            '<div class="text-end ms-3">' +
            '<span class="badge bg-info category-badge">' + escapeHtml(item.category || '鏈垎绫?) + '</span>' +
            '<div class="mt-2">' +
            '<button class="btn btn-outline-danger btn-sm py-0 px-1" title="鍒犻櫎" onclick="del(' + item.id + ')">馃棏</button>' +
            '</div>' +
            '</div>' +
            '</div>' +
            (item.keywords ? '<div class="mt-1">' + item.keywords.split(',').map(k => '<span class="kw-tag">' + escapeHtml(k.trim()) + '</span>').join('') + '</div>' : '') +
            '<div class="text-muted small mt-1">鏉ユ簮锛? + escapeHtml(item.source || '鎵嬪姩杈撳叆') + ' | ' + date + '</div>' +
            '</div>';
    });
    html += '</div>';
    container.innerHTML = html;
}

function ingest() {
    const title = document.getElementById('ingestTitle').value.trim();
    const content = document.getElementById('ingestContent').value.trim();
    const category = document.getElementById('ingestCategory').value.trim();
    if (!title || !content) { showMsg('鏍囬鍜屽唴瀹逛笉鑳戒负绌?, 'danger'); return; }
    fetch('/api/knowledge/ingest', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({title: title, content: content, category: category || '鏈垎绫?, source: 'Web鐣岄潰'})
    })
    .then(r => { if (!r.ok) throw new Error('褰曞叆澶辫触'); return r.json(); })
    .then(() => {
        document.getElementById('ingestTitle').value = '';
        document.getElementById('ingestContent').value = '';
        document.getElementById('ingestCategory').value = '';
        showMsg('褰曞叆鎴愬姛', 'success');
        loadAll(); loadStats();
    })
    .catch(err => showMsg(err.message, 'danger'));
}

function del(id) {
    if (!confirm('纭鍒犻櫎锛?)) return;
    fetch('/api/knowledge/' + id, { method: 'DELETE' })
        .then(r => { if (!r.ok) throw new Error('鍒犻櫎澶辫触'); showMsg('鍒犻櫎鎴愬姛', 'success'); loadAll(); loadStats(); })
        .catch(err => showMsg(err.message, 'danger'));
}

function rebuildIndex() {
    fetch('/api/knowledge/rebuild-index', { method: 'POST' })
        .then(r => r.text())
        .then(msg => { showMsg(msg, 'success'); loadStats(); })
        .catch(err => showMsg(err.message, 'danger'));
}

function showMsg(msg, type) {
    const area = document.getElementById('msgArea');
    area.innerHTML = '<span class="text-' + type + '">' + msg + '</span>';
    setTimeout(() => area.innerHTML = '', 3000);
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// === 鏂囦欢涓婁紶 ===
function handleFileSelect(event) {
    const file = event.target.files[0];
    if (!file) return;
    document.getElementById('fileLabel').textContent = '宸查€夋嫨: ' + file.name;
    showMsg('姝ｅ湪瀵煎叆鏂囦欢: ' + file.name + '...', 'info');

    const formData = new FormData();
    formData.append('file', file);

    fetch('/api/knowledge/import', { method: 'POST', body: formData })
        .then(r => {
            if (!r.ok) {
                return r.json().then(errData => {
                    throw new Error(errData.error || errData.message || '瀵煎叆澶辫触');
                }).catch(e => {
                    if (e.message && e.message !== '瀵煎叆澶辫触') throw e;
                    throw new Error('瀵煎叆澶辫触 (HTTP ' + r.status + ')');
                });
            }
            return r.json();
        })
        .then(data => {
            showMsg('瀵煎叆鎴愬姛锛佸垎鐗囨暟: ' + data.chunkCount + '锛屽叏灞€鍏抽敭璇? ' + (data.globalKeywords || []).join(', '), 'success');
            document.getElementById('fileLabel').textContent = '';
            document.getElementById('fileInput').value = '';
            loadAll(); loadStats();
        })
        .catch(err => {
            showMsg('瀵煎叆澶辫触: ' + err.message, 'danger');
            document.getElementById('fileLabel').textContent = '';
            document.getElementById('fileInput').value = '';
        });
}
</script>
</body>
</html>


